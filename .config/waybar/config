{
  "height": 20,
  "spacing": 4,
  "bar_id": "bar-0",
  "ipc": true,
  "hidden_state": "show",
  "modules-left": [
    "clock",
    "mpris",
    "custom/updates"
  ],
  "modules-center": [
    "sway/workspaces"
  ],
  "modules-right": [
    "tray",
    "custom/pacman",
    "custom/power-profile",
    "custom/dpi",
    "custom/keep-alive",
    "custom/theme",
    "pulseaudio",
    "custom/network",
    "battery"
  ],
  "custom/keep-alive": {
    "exec": "~/.config/waybar/scripts/keep-alive",
    "on-click": "~/.config/waybar/scripts/keep-alive --toggle",
    "return-type": "json",
    "interval": 2
  },
  "custom/theme": {
    "exec": "~/.config/waybar/scripts/toggle-theme",
    "on-click": "~/.config/waybar/scripts/toggle-theme --toggle",
    "restart-interval": 2
  },
  "custom/power-consumption": {
    "exec": "~/.config/waybar/scripts/power-consumption"
  },
  "custom/power-profile": {
    "exec": "~/.config/waybar/scripts/power-profile",
    "on-click": "~/.config/waybar/scripts/power-profile --toggle",
    "interval": 2
  },
  "custom/dpi": {
    "exec": "~/.config/waybar/scripts/toggle-hdpi",
    "on-click": "~/.config/waybar/scripts/toggle-hdpi --toggle",
    "restart-interval": 2
  },
  "clock": {
    "interval": 60,
    "format": "{:%H:%M}",
    "on-click": "gnome-calendar",
    "max-length": 25
  },
  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{capacity}%  {icon}",
    "format-charging": "{capacity}% ΎΩπ",
    "format-plugged": "{capacity}% ΎΘο",
    "format-alt": "{time} {icon}",
    "format-icons": [
      "ΎΚΕ",
      "ΎΚΔ",
      "ΎΚΓ",
      "ΎΚΒ",
      "ΎΚΑ"
    ]
  },
  "wlr/workspaces": {
    "format": "{icon}",
    "on-click": "activate",
    "format-icons": {
      "1": "ΎΕι",
      "2": "ΎΚρ",
      "3": "ΎΕκ",
      "4": "ΎΗ╝",
      "5": "ΎΒ╡",
      "urgent": "ΎΒς",
      "active": "ΎΗΤ",
      "default": "ΎΕΣ"
    },
    "sort-by-number": true
  },
  "sway/workspaces": {
    "format": "{icon}{name}",
    "format-icons": {
      "1: Code": "ΌτΕ",
      "2: Browser": "≤░Ψθ",
      "3: Chat": "ΎΒ╡",
      "4: Music": "Ό░δ",
      "urgent": "ΎΒς",
      "default": ""
    }
  },
  // "network": {
  //   "family":"ipv4",
  //   "exec": "~/.config/waybar/scripts/network",
  //   "format-wifi": "{essid} ({signalStrength}%)",
  //   "format-ethernet": "{ipaddr}/{cidr}",
  //   "tooltip-format": "{ifname} via {gwaddr}",
  //   "format-linked": "{ifname} (No IP) ΎηΨ",
  //   "format-disconnected": "≤▒γ╡",
  //   "format-alt": "{ifname}: {ipaddr}/{cidr}"
  // },
  "custom/network": {
    "format": "{}",
    "exec": "~/.config/waybar/scripts/network",
    "interval": 5
  },
  "pulseaudio": {
    "format": "{volume}% {icon}  {format_source}",
    "format-bluetototh": "{volume}% {icon}ΎΛΦ {format_source}",
    "format-bluetooth-muted": " {icon}ΎΛΦ {format_source}",
    "format-muted": "Ύγσ {format_source}",
    "format-source": "{volume}% ΎΕ░",
    "format-source-muted": "ΎΕ▒",
    "format-icons": {
      "headphone": "≤░ΜΜ",
      "hands-free": "≤░ξ░",
      "headset": "≤░ΜΟ",
      "phone": "ΎΓΧ",
      "portable": "ΎΓΧ",
      "car": "ΎΗ╣",
      "default": [
        "ΎΑο",
        "ΎΑπ",
        "ΎΑρ"
      ]
    },
    "on-right-click": "~/.config/waybar/scripts/mic-toggle --toggle",
    "on-click": "pavucontrol"
  },
  "custom/updates": {
    "exec": "~/.config/waybar/scripts/check-updates",
    "interval": 3600, // 3600 seconds = 1 hour
    "return-type": "json",
    "tooltip": true,
    "on-click": "~/.config/waybar/scripts/check-updates update"
  },
  "mpris": {
    "format": "{player_icon} {dynamic}",
    "format-paused": "{status_icon} <i>{dynamic}</i>",
     "title-len": 32,
     "album-len": 0,
     "artist-len": 0,
    "player-icons": {
      "default": "έΠ╕",
      "mpv": "ΏθΟ╡"
    },
    "status-icons": {
      "paused": "έΨ╢"
    }
  },
  "tray": {
    "icon-size": 16,
    "spacing": 0
  }
}
